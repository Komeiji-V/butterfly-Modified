if theme.subtitle.enable
  //- 修正：重新补回被漏掉的打字机核心库加载
  script(src=url_for(theme.asset.typed))
  script.
    function initTyped() {
      // 检查当前页面是否存在打字机容器
      var subtitleElement = document.getElementById('subtitle');
      if (!subtitleElement) return;

      // 获取配置的副标题数组
      var subString = "!{theme.subtitle.sub}";
      var subArray = subString ? subString.split(",") : ["欢迎来到我的博客"];
      
      // 去除空字符串
      subArray = subArray.filter(function(item) { return item.trim() !== ''; });
      if (subArray.length === 0) { subArray = ["记录点滴生活"]; }

      // 洗牌算法 (随机打乱数组)
      for (var i = subArray.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var temp = subArray[i];
        subArray[i] = subArray[j];
        subArray[j] = temp;
      }

      // 防抖与销毁旧实例 (修复开启 PJAX 后重复打字重叠的 BUG)
      if (window.typed) {
        window.typed.destroy();
      }

      // 延迟 3 秒启动
      setTimeout(function() {
        if (window.Typed) {
          window.typed = new Typed("#subtitle", {
            strings: subArray,
            startDelay: 300,
            typeSpeed: 150,  
            loop: true,
            backSpeed: 50    
          });
        }
      }, 3000); 
    }

    // 初始化执行
    initTyped();
    // 兼容 PJAX 页面切换后重新执行
    document.addEventListener('pjax:complete', initTyped);
